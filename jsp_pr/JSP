				시작값은 양수만 가능
				증가값은 증가만 가능
			</c:forEach>	
		
			-배열 출력
				- 주의: 숫자를 출력하는 속성은 사용하지 않는다. (begin,end,step)
			<c:forEach var="변수명" item="${ 배열명, collction명 }" varStatus="증가하는 값을 저장하는 객체">
				${변수명}
			</c:foreach>
			
			<%
			1. 배열, collection생성, 얻기.
			String[] arr = {"","","","",""};//서비스객체.method()
			2. scope 객체에 저장
			pageContext.setAttribute("이름", 배열명);
			%>
			3. 반복
			<c:forEach var="변수명" items="${scope객체명}" varStatus="i">
				${i.count} ${변수명}
			</c:forEach>
			
