		1. URL 생성
		URL url = new URL("경로");
		2. URLConnection 얻기
		URLConnection uc = url.openConnection();
		3. Stream 얻기
		BufferedReader br = new BufferedReader(new InputStreamReader(uc.getInputStream()));
		4. Stream에서 XML 읽어오기
		String line = "";
		while(line = br.readLine()){
			line;
		}// end while
		5. 연결 끊기
		br.close();
		
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	